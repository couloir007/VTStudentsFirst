<?php
 /**
 * @file
 * Functions to support theming in the Olivero theme.
 */

/**
 * Load include files which contain additional theming logic.
 */
foreach (glob(\Drupal::service('extension.list.theme')->getPath('surface') . '/includes/*.theme') as $file) {
  include $file;
}

