{{ attach_library('surface/action-section') }}

<section class="action-section{{ modifier ? ' ' ~ modifier }}{{- attributes ? ' ' ~ attributes.class -}}"
  {{- attributes ? attributes|without(class) -}}
  {% if civic_api_key %}data-civic-api-key="{{ civic_api_key }}"{% endif %}
>
  <div class="action-section__inner">
    <div class="action-section__header">
      {% if section_label %}
        <span class="action-section__label">{{ section_label }}</span>
      {% endif %}
      {% if section_headline %}
        <h2 class="action-section__headline">{{ section_headline }}</h2>
      {% endif %}
      {% if body_text %}
        <p class="action-section__lead">{{ body_text|raw }}</p>
      {% endif %}
    </div>

    {% if steps %}
      <div class="action-section__steps">
        {% for step in steps %}
          {% include "@components/step-item/step-item.twig" with {
            number: loop.index,
            headline: step.headline,
            body: step.body,
            cta: step.cta
          } only %}
        {% endfor %}
      </div>
    {% endif %}

    {# ── Rep Lookup Widget ──────────────────────────────────────────────── #}
    <div class="rep-lookup" id="rep-lookup">
      <h3 class="rep-lookup__headline">Find Your Representative</h3>
      <p class="rep-lookup__sub">Enter your street address to find your Vermont House representative and their direct contact information — then use the templates below to reach out.</p>

      <form class="rep-lookup__form" id="rep-lookup-form" novalidate>
        <input
          class="rep-lookup__input"
          id="rep-lookup-address"
          type="text"
          placeholder="123 Main St, Danville"
          autocomplete="street-address"
          aria-label="Your street address"
          required
        >
        <button class="rep-lookup__btn" id="rep-lookup-btn" type="submit">
          Find My Rep
        </button>
      </form>

      <p class="rep-lookup__error" id="rep-lookup-error" hidden></p>

      <div class="rep-lookup__result" id="rep-lookup-result" hidden>
        <p class="rep-lookup__result-label">Your Vermont House Representative</p>
        <div class="rep-lookup__cards" id="rep-lookup-cards"></div>

        <div class="rep-lookup__toolkit-prompt" id="rep-lookup-toolkit-prompt" hidden>
          <p>Letter template pre-filled for <strong class="rep-lookup__rep-name"></strong> — ready to copy below.</p>
          <button class="rep-lookup__jump-btn" onclick="document.getElementById('tab-legislator').scrollIntoView({behavior:'smooth'});showTab('legislator');">
            Go to Letter →
          </button>
        </div>
      </div>
    </div>

    {% if toolkit %}
      <div class="action-section__toolkit">
        <h3 class="action-section__toolkit-headline">{{ toolkit.headline|default('Advocacy Toolkit') }}</h3>
        <p class="action-section__toolkit-sub">{{ toolkit.subheadline }}</p>

        <div class="action-section__tabs">
          <div class="action-section__tab-buttons">
            {% for tab in toolkit.tabs %}
              <button class="action-section__tab-btn{{ loop.first ? ' active' : '' }}" data-tab="{{ tab.id }}">{{ tab.title }}</button>
            {% endfor %}
          </div>

          <div class="action-section__tab-content">
            {% for tab in toolkit.tabs %}
              <div id="tab-{{ tab.id }}" class="action-section__tab-panel{{ loop.first ? ' active' : '' }}">
                <div class="action-section__toolkit-grid">
                  {% for item in tab.items %}
                    <div class="action-section__toolkit-card">
                      <h5>{{ item.title }}</h5>
                      <p id="text-{{ item.id }}">{{ item.content }}</p>
                      <button class="action-section__copy-btn" onclick="copyText('text-{{ item.id }}')">Copy Text</button>
                    </div>
                  {% endfor %}
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
      </div>
    {% endif %}
  </div>
</section>
