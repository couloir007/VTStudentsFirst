msgid "Encrypt File"
msgstr "Chiffrer le fichier"
msgid "Decrypt file"
msgstr "Déchiffrer le fichier"
msgid "Password for encrypting / decrypting the file"
msgstr "Mot de passe pour chiffrer/déchiffrer le fichier"
