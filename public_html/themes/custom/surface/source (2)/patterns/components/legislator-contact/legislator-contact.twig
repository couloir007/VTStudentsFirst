{{ attach_library('surface/legislator-contact') }}

<div class="legislator-contact{{ modifier ? ' ' ~ modifier }}"
  id="legislator-contact"
  {% if civic_api_key %}data-civic-api-key="{{ civic_api_key }}"{% endif %}
>

  {# ── Form view (default) ────────────────────────────────────────────── #}
  <div class="lc-form" id="lc-form">
    <h3 class="lc-form__title">Contact Your Legislator</h3>
    <p class="lc-form__sub">Fill in your info and we'll connect you with your Vermont House and Senate representatives. Personal messages carry far more weight than form letters.</p>

    <div class="lc-field-row">
      <div class="lc-field">
        <label class="lc-field__label" for="lc-fname">First Name</label>
        <input class="lc-field__input" id="lc-fname" type="text" placeholder="Jane" autocomplete="given-name">
      </div>
      <div class="lc-field">
        <label class="lc-field__label" for="lc-lname">Last Name</label>
        <input class="lc-field__input" id="lc-lname" type="text" placeholder="Smith" autocomplete="family-name">
      </div>
    </div>

    <div class="lc-field">
      <label class="lc-field__label" for="lc-email">Email Address</label>
      <input class="lc-field__input" id="lc-email" type="email" placeholder="jane@example.com" autocomplete="email">
    </div>

    <div class="lc-field">
      <label class="lc-field__label" for="lc-town">Your Town</label>
      <input class="lc-field__input" id="lc-town" type="text" placeholder="e.g. Danville, Sutton, Newark…" autocomplete="address-level2">
    </div>

    <div class="lc-field">
      <label class="lc-field__label" for="lc-role">Your Connection</label>
      <select class="lc-field__select" id="lc-role">
        <option value="">Select one…</option>
        <option>Parent of a tuitioning student</option>
        <option>Student</option>
        <option>Teacher / School staff</option>
        <option>Local employer</option>
        <option>Community member / Alumnus</option>
        <option>Elected official</option>
        <option>Other</option>
      </select>
    </div>

    <div class="lc-field">
      <label class="lc-field__label" for="lc-message">Your Message <span class="lc-field__optional">(personalize for more impact)</span></label>
      <textarea class="lc-field__textarea" id="lc-message" rows="5">My name is [Your Name] and I am a constituent from [Town]. I am writing to share my strong opposition to proposals that would eliminate supervisory unions and restrict Vermont's Town Tuition Program. I understand the need for education reform, but eliminating choice and access to independent schools does nothing to save money or improve quality. Please oppose any plan that restricts family choice or consolidates our district against our will.</textarea>
    </div>

    <p class="lc-form__error" id="lc-form-error" hidden></p>

    <button class="lc-btn lc-btn--primary lc-btn--full" id="lc-submit-btn" type="button">
      Send to My Legislators →
    </button>

    <p class="lc-form__note">We'll match your town to your representatives and send on your behalf. We never share your information. You can also contact the <a href="https://governor.vermont.gov/contact-us-requests" target="_blank" rel="noopener">Governor's Office directly</a>.</p>
  </div>

  {# ── Confirmation view (shown after submit) ─────────────────────────── #}
  <div class="lc-confirm" id="lc-confirm" hidden>
    <div class="lc-confirm__icon">✓</div>
    <h3 class="lc-confirm__headline">Message ready to send!</h3>
    <p class="lc-confirm__body">Your email client should open with your message pre-addressed to your representative(s). If it didn't open, copy your message below and paste it into your own email.</p>

    <div class="lc-confirm__reps" id="lc-confirm-reps"></div>

    <div class="lc-confirm__copy-wrap">
      <textarea class="lc-field__textarea lc-confirm__copy-msg" id="lc-confirm-msg" rows="8" readonly></textarea>
      <button class="lc-btn lc-btn--ghost" id="lc-copy-btn" type="button">Copy Message</button>
    </div>

    <div class="lc-confirm__next">
      <p class="lc-confirm__next-label">What's next?</p>
      <ul class="lc-confirm__next-list">
        <li>Share this page with a neighbor on Front Porch Forum or Facebook</li>
        <li>Attend your local school board meeting and speak during public comment</li>
        <li>Write a letter to your local paper using the templates in our toolkit below</li>
      </ul>
    </div>

    <button class="lc-btn lc-btn--ghost" id="lc-restart" type="button">Send another message</button>
  </div>

</div>
