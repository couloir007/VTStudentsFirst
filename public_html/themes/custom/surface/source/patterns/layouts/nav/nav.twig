{{ attach_library('surface/nav') }}

{% set classes = [
  'nav',
  attributes ? attributes.class
]|join(' ')|trim %}

{% set title_classes = [
  'nav__title',
  title_hidden ? 'visually-hidden',
  title_attributes ? title_attributes.class,
]|join(' ')|trim %}

<nav class="{{ classes }}" {{ attributes ? attributes|without('class', 'id') }} aria-labelledby="{{ heading_id }}" role="navigation">
  {{ title_prefix }}
  <div class="{{ title_classes }}" {{ title_attributes ? title_attributes|without('class') }} id="{{ heading_id }}">{{ label }}</div>
  {{ title_suffix }}

  {% block content %}
    {{ content }}
  {% endblock %}
</nav>
