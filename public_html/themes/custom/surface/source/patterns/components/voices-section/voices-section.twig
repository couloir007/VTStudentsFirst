{{ attach_library('surface/voices-section') }}

<section class="voices-section{{ modifier ? ' ' ~ modifier }}{{- attributes ? ' ' ~ attributes.class -}}" {{- attributes ? attributes|without(class) -}}>
  <div class="voices-section__inner">
    {% if section_label %}
      <span class="voices-section__label">{{ section_label }}</span>
    {% endif %}
    {% if section_headline %}
      <h2 class="voices-section__headline">{{ section_headline|raw }}</h2>
    {% endif %}
    {% if body_text %}
      <p class="voices-section__lead">{{ body_text|raw }}</p>
    {% endif %}

    {% if voices %}
      <div class="voices-section__grid">
        {% for voice in voices %}
          {% include "@components/testimonial/testimonial.twig" with {
            quote: voice.quote,
            attribution: (voice.name ?: '') ~ (voice.role ? ' — ' ~ voice.role : '')
          } only %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>
