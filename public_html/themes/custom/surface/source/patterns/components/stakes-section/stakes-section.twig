{{ attach_library('surface/stakes-section') }}

<section class="stakes-section{{ modifier ? ' ' ~ modifier }}{{- attributes ? ' ' ~ attributes.class -}}" {{- attributes ? attributes|without(class) -}}>
  <div class="stakes-section__inner">
    {% if section_label %}
      <span class="stakes-section__label">{{ section_label }}</span>
    {% endif %}
    {% if section_headline %}
      <h2 class="stakes-section__headline">{{ section_headline|raw }}</h2>
    {% endif %}
    {% if body_text %}
      <div class="stakes-section__lead">{{ body_text|raw }}</div>
    {% endif %}

    {% if stakes_items %}
      <div class="stakes-section__grid">
        {% for item in stakes_items %}
          {% include "@components/card-item/card-item.twig" with {
            variant: 'stake',
            title: item.headline,
            body: item.body
          } only %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>
