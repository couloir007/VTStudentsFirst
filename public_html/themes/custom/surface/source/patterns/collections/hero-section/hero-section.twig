{{ attach_library('surface/hero-section') }}

{% embed "@layouts/section/section.twig" with {
  section_class: 'hero-section',
  attributes: attributes,
  modifier: modifier
} %}
  {% block section_content %}
    <div class="hero-section__bg"></div>

    <!-- Mountain silhouette -->
    <svg class="hero-section__mountains" viewBox="0 0 1440 320" preserveAspectRatio="xMidYMax slice" xmlns="http://www.w3.org/2000/svg">
      <path fill="rgba(122,171,138,1)" d="M0,320 L0,200 L120,140 L240,190 L360,100 L480,160 L560,80 L650,130 L720,60 L800,110 L900,40 L980,90 L1080,30 L1160,85 L1260,50 L1360,100 L1440,70 L1440,320 Z"/>
      <path fill="rgba(44,86,64,1)" d="M0,320 L0,250 L100,200 L200,230 L320,170 L420,210 L520,150 L620,190 L700,130 L780,170 L880,110 L980,155 L1080,100 L1180,145 L1280,115 L1380,150 L1440,130 L1440,320 Z"/>
      <path fill="rgba(29,58,42,1)" d="M0,320 L0,285 L150,255 L280,270 L400,240 L520,260 L640,225 L760,250 L880,215 L1000,245 L1120,220 L1240,245 L1360,228 L1440,240 L1440,320 Z"/>
    </svg>

    <div class="section__inner hero-section__content">
      {% if eyebrow %}
        <p class="hero-section__eyebrow">{{ eyebrow }}</p>
      {% endif %}
      {% if headline %}
        <h1 class="hero-section__headline">{{ headline|raw }}</h1>
      {% endif %}
      {% if subheadline %}
        <p class="hero-section__subheadline">{{ subheadline }}</p>
      {% endif %}

      <div class="hero-section__actions">
        {% if cta_primary %}
          <a href="{{ cta_primary.url }}" class="hero-section__btn-primary">{{ cta_primary.title }}</a>
        {% endif %}
        {% if cta_secondary %}
          <a href="{{ cta_secondary.url }}" class="hero-section__btn-secondary">{{ cta_secondary.title }}</a>
        {% endif %}
      </div>
    </div>

    {% if stats %}
      <div class="section__inner hero-section__scroll">
        {% for stat in stats %}
          {% include "@elements/stat-item/stat-item.twig" with {
            'number': stat.number,
            'label': stat.label,
            'modifier': 'hero-section__stat'
          } only %}
        {% endfor %}
      </div>
    {% endif %}
  {% endblock %}
{% endembed %}
