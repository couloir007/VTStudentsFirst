{{ attach_library('surface/positions-section') }}

{% embed "@layouts/section/section.twig" with {
  section_class: 'positions-section',
  inner_class: 'positions-section__inner',
  attributes: attributes,
  modifier: modifier
} %}
  {% block content %}
    {% if section_label %}
      {% include "@elements/section-label/section-label.twig" with {
        text: section_label,
        class: 'positions-section__label'
      } only %}
    {% endif %}

    {% if section_headline %}
      {% include "@elements/section-headline/section-headline.twig" with {
        text: section_headline,
        modifier: 'black',
        class: 'positions-section__headline'
      } only %}
    {% endif %}

    {% if body_text %}
      <p class="positions-section__lead">{{ body_text|raw }}</p>
    {% endif %}

    {% if positions %}
      <div class="positions-section__grid">
        {% for position in positions %}
          {% include "@components/position-item/position-item.twig" with {
            number: loop.index,
            headline: position.headline,
            body: position.body
          } only %}
        {% endfor %}
      </div>
    {% endif %}
  {% endblock %}
{% endembed %}
