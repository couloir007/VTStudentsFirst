{% if (get) %}
  {% set keys = get.keywords %}
{% else %}
  {% set keys = "" %}
{% endif %}

{% set exposed %}
  {% include '@components/view-listing-form/view-listing-form.twig' with {
    'action': path,
    'aria_label': 'Filter the contents of the Recent Search view',
    'name': 'search-listing',
    'keys': keys,
    'placeholder': 'Search by keyword',
  } only %}
{% endset %}

{% set facets %}
  {{ drupal_entity('block', 'search_content_type') }}
{% endset %}

{% set classes = [
  'view-' ~ id|clean_class,
  'view-id-' ~ id,
  'view-display-id-' ~ display_id,
  dom_id ? 'js-view-dom-id-' ~ dom_id
] %}

{% set attributes = attributes.addClass(classes) %}

{% include '@layouts/view-listing/view-listing.twig' with {
  'attributes': attributes,
  'title_prefix': title_prefix,
  'title': title,
  'title_suffix': title_suffix,
  'header': header,
  'exposed': exposed,
  'facets': facets,
  'rows': rows,
  'empty': empty,
  'pager': pager,
} %}
