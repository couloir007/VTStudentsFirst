{% embed '@layouts/article-highlight/article-highlight.twig' with {
  'attributes': attributes,
  'theme': data_theme,
  'heading': content.field_sf_title|field_value is not empty ? content.field_sf_title|field_value,
  'url': content.field_sf_link|field_value is not empty ? content.field_sf_link.0['#url_title'],
  'url_title': content.field_sf_link|field_value is not empty ? content.field_sf_link.0['#title'],
  'featured': content.field_sf_featured_article|field_value is not empty ? content.field_sf_featured_article|field_value,
} %}
  {% block view %}
    {% if content.field_sf_featured_article|field_value is not empty %}
      {% set article_id = content.field_sf_featured_article.0['#node'].nid.value %}
    {% else %}
      {% set article_id = "all" %}
    {% endif %}

    {% if content.field_sf_filter_articles|field_value is not empty %}
      {% set terms = content.field_sf_filter_articles|field_value|safe_join(', ') %}
    {% else %}
      {% set terms = "all" %}
    {% endif %}

    {{ drupal_view('articles_highlight', 'default', terms, article_id) }}
  {% endblock %}
{% endembed %}
