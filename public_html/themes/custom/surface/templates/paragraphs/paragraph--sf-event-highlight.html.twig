{% embed '@layouts/article-highlight/article-highlight.twig' with {
  'attributes': attributes,
  'theme': data_theme,
  'heading': content.field_sf_title|field_value is not empty ? content.field_sf_title|field_value,
  'url': content.field_sf_link|field_value is not empty ? content.field_sf_link.0['#url_title'],
  'url_title': content.field_sf_link|field_value is not empty ? content.field_sf_link.0['#title'],
  'featured': content.field_sf_featured_event|field_value is not empty ? content.field_sf_featured_event|field_value,
} %}
  {% block view %}
    {% if content.field_sf_featured_event|field_value is not empty %}
      {% set event_id = content.field_sf_featured_event.0['#node'].nid.value %}
    {% else %}
      {% set event_id = "all" %}
    {% endif %}

    {% if content.field_sf_filter_events|field_value is not empty %}
      {% set terms = content.field_sf_filter_events|field_value|safe_join(', ') %}
    {% else %}
      {% set terms = "all" %}
    {% endif %}

    {{ drupal_view('events_highlight', 'default', terms, event_id) }}
  {% endblock %}
{% endembed %}
