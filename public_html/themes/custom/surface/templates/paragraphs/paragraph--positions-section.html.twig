{#
/**
 * @file paragraph--positions-section.html.twig
 *
 * Paragraph bundle: PositionsSection
 * Component:        @collections/positions-section/positions-section.twig
 *
 * Fields
 *   field_section_label    (string)       → section_label
 *   field_section_headline (string)       → section_headline (raw)
 *   field_intro_text       (text_long)    → body_text
 *   field_position_items   (er_rev)       → positions[] from PositionItem paragraphs
 *                                           each child: field_position_title,
 *                                                       field_position_body
 */
#}
{% set positions = [] %}
{% for item in paragraph.field_position_items %}
  {% set positions = positions|merge([{
    headline: item.entity.field_position_title.value,
    body:     item.entity.field_position_body.value,
  }]) %}
{% endfor %}

{% include "@collections/positions-section/positions-section.twig" with {
  section_label:    paragraph.field_section_label.value,
  section_headline: paragraph.field_section_headline.value,
  body_text:        paragraph.field_intro_text.value,
  positions:        positions,
  attributes:       attributes,
  'id':             paragraph.field_section_url.value,
} only %}
