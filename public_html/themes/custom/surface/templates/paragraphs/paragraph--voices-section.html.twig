{#
/**
 * @file paragraph--voices-section.html.twig
 *
 * Paragraph bundle: VoicesSection
 * Component:        @collections/voices-section/voices-section.twig
 *
 * Voices references node:Testimonial entities (not nested paragraphs).
 *
 * Fields
 *   field_section_label    (string)       → section_label
 *   field_section_headline (string)       → section_headline (raw)
 *   field_intro_text       (text_long)    → body_text
 *   field_testimonials     (er)           → voices[] from node:Testimonial
 *
 * node:Testimonial fields consumed:
 *   title → voice.name  (attribution — who said it)
 *   body  → voice.quote (the quote text)
 */
#}
{% set voices = [] %}
{% for item in paragraph.field_testimonials %}
  {% set voices = voices|merge([{
    quote: item.entity.body.value,
    name:  item.entity.title.value,
    role:  '',
  }]) %}
{% endfor %}

{% include "@collections/voices-section/voices-section.twig" with {
  section_label:    paragraph.field_section_label.value,
  section_headline: paragraph.field_section_headline.value,
  body_text:        paragraph.field_intro_text.value,
  voices:           voices,
  attributes:       attributes,
  'id':               paragraph.field_section_url.value,
} only %}
