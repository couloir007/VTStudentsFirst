{#
/**
 * @file paragraph--voices-section.html.twig
 *
 * Paragraph bundle: VoicesSection
 * Component:        @components/voices-section/voices-section.twig
 *
 * Voices references node:Testimonial entities (not nested paragraphs).
 *
 * Fields
 *   field_section_label    (string)       → section_label
 *   field_section_headline (string)       → section_headline (raw)
 *   field_intro_text       (text_long)    → body_text
 *   field_testimonials     (er)           → voices[] from node:Testimonial
 *
 * node:Testimonial fields consumed:
 *   field_quote_text        → voice.quote
 *   field_quote_attribution → voice.name (full attribution string)
 *   field_quote_anonymous   → if TRUE, attribution is suppressed
 */
#}
{% set voices = [] %}
{% for node in paragraph.field_testimonials.referencedEntities() %}
  {% set is_anonymous = node.field_quote_anonymous.value %}
  {% set voices = voices|merge([{
    quote: node.field_quote_text.value,
    name:  is_anonymous ? 'Community Member' : node.field_quote_attribution.value,
    role:  is_anonymous ? '(name withheld)' : '',
  }]) %}
{% endfor %}

{% include "@components/voices-section/voices-section.twig" with {
  section_label:    paragraph.field_section_label.value,
  section_headline: paragraph.field_section_headline.value,
  body_text:        paragraph.field_intro_text.value,
  voices:           voices,
  attributes:       attributes,
} only %}
