{#
/**
 * @file paragraph--stakes-section.html.twig
 *
 * Paragraph bundle: StakesSection
 * Component:        @components/stakes-section/stakes-section.twig
 *
 * Fields
 *   field_section_label    (string)       → section_label
 *   field_section_headline (string)       → section_headline (raw)
 *   field_intro_text       (string)       → body_text
 *   field_cards            (er_rev)       → stakes_items[] from CardItem paragraphs
 *                                           each child: field_card_title (headline),
 *                                                       field_card_body
 */
#}
{% set stakes_items = [] %}
{% for card in paragraph.field_cards.referencedEntities() %}
  {% set stakes_items = stakes_items|merge([{
    headline: card.field_card_title.value,
    body:     card.field_card_body.value,
  }]) %}
{% endfor %}

{% include "@components/stakes-section/stakes-section.twig" with {
  section_label:    paragraph.field_section_label.value,
  section_headline: paragraph.field_section_headline.value,
  body_text:        paragraph.field_intro_text.value,
  stakes_items:     stakes_items,
  attributes:       attributes,
} only %}
