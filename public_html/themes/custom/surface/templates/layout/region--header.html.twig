{#
/**
 * @file region--header.html.twig
 *
 * Delegates to site-header.twig for all markup.
 * Passes the Header region's block content into the menu block slot.
 *
 * Expected blocks in this region:
 *   - Main navigation menu block → menu-main.twig via
 *     block--system-menu-block--main.html.twig
 *
 * @see layouts/site-header/site-header.twig
 * @see block--system-menu-block--main.html.twig
 * @see template_preprocess_region()
 */
#}
{% if content %}
  {% embed '@layouts/site-header/site-header.twig' with {
    logo_url: path('<front>'),
  } %}
    {% block menu %}
      {{ content }}
    {% endblock %}
  {% endembed %}
{% endif %}
