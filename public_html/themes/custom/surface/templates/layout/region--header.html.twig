{#
/**
 * @file
 * Surface's theme override to display the header region.
 *
 * Available variables:
 * - content: The content for this region, typically blocks.
 * - attributes: HTML attributes for the region <div>.
 * - region: The name of the region variable as defined in the theme's
 *   .info.yml file.
 *
 * @see template_preprocess_region()
 */
#}



{% if content %}
  {% embed '@layouts/site-header/site-header.twig' %}

    {% block primary %}
      <ul class="menu-main menu-main--dropdown menu-main--level-1" data-type="dropdown" data-drupal-selector="menu-main--level-1">
        <li class="menu__item menu__item--link menu__item--level-1{% if is_front %} menu__item--active-trail{% endif %}">
          <a href="{{ path('<front>') }}" class="menu__link menu__link--link menu__link--level-1{% if is_front %} menu__link--active-trail is-active{% endif %}" data-drupal-selector="menu__link--has-children" data-drupal-link-system-path="node/2" aria-current="page">
            {% if is_front %}
              <h1 class="menu__link-inner menu__link-inner--level-1">
            {% else %}
              <span class="menu__link-inner menu__link-inner--level-1">
            {% endif %}
            Sean Montague
            {% if is_front %}
              </h1>
            {% else %}
              </span>
            {% endif %}
          </a>
        </li>
      </ul>
      {% if is_front %}</h1>{% endif %}
      {% embed '@layouts/site-navigation/site-navigation.twig' %}
        {% block menu %}
          {{ drupal_menu('main', expand=true) }}
        {% endblock %}
      {% endembed %}
      {% include '@components/mobile-button/mobile-button.twig' %}
    {% endblock %}

    {% block buttons %}
      {% include '@components/translate/translate.twig' only %}
      {% include '@components/button-search/button-search.twig' with {
        'label': 'Search',
        'is_demo': false
      } %}
      {% include '@components/contact/contact.twig' with {
        'url': '/contact',
        'text': 'Contact Sean'
      } only %}
    {% endblock %}

    {% block search %}
      {% embed '@components/site-search/site-search.twig' with {
        'data_search': 'modal',
        'has_quicklinks': drupal_menu('quick-links')|render is not empty
      } %}
        {% block quicklinks %}
          {{ drupal_menu('quick-links') }}
        {% endblock %}
      {% endembed %}
    {% endblock %}
  {% endembed %}
{% endif %}
