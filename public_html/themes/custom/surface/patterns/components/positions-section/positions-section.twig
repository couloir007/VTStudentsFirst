{{ attach_library('surface/positions-section') }}

<section class="positions-section{{ modifier ? ' ' ~ modifier }}{{- attributes ? ' ' ~ attributes.class -}}" {{- attributes ? attributes|without(class) -}}>
  <div class="positions-section__inner">
    {% if section_label %}
      <span class="positions-section__label">{{ section_label }}</span>
    {% endif %}
    {% if section_headline %}
      <h2 class="positions-section__headline">{{ section_headline|raw }}</h2>
    {% endif %}
    {% if body_text %}
      <p class="positions-section__lead">{{ body_text|raw }}</p>
    {% endif %}

    {% if positions %}
      <div class="positions-section__grid">
        {% for position in positions %}
          {% include "@components/position-item/position-item.twig" with {
            number: loop.index,
            headline: position.headline,
            body: position.body
          } only %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>
