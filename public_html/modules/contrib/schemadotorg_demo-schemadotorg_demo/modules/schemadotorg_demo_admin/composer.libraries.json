      },
      "drupal/moderation_sidebar": {
        "Issue #3468716: Default Drupal core's moderation control widget to hidden when this module is enabled": "https://www.drupal.org/files/issues/2024-08-17/moderation_sidebar-issue-3468716-comment-3.patch"
