    "drupal/masquerade": "^2.0",
    "drupal/media_file_delete":  "^1.0",
    "drupal/moderated_content_bulk_publish": "^2.0",
    "drupal/moderation_dashboard": "^3.0",
    "drupal/moderation_sidebar": "^1.0",
