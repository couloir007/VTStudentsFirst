{#
/**
 * @file paragraph--issue-section.html.twig
 *
 * Paragraph bundle: IssueSection
 * Component:        @components/issue-section/issue-section.twig
 *
 * Fields
 *   field_section_label    (string)       → section_label
 *   field_section_headline (string_long)  → section_headline (raw, supports <em>)
 *   field_intro_text       (text_long)    → lead_text (main prose block)
 *   field_cards            (er_rev)       → issue_cards[] from CardItem paragraphs
 *                                           each child: field_card_title,
 *                                                       field_card_body,
 *                                                       field_card_variant
 */
#}
{% set issue_cards = [] %}
{% for item in paragraph.field_cards %}
  {% set issue_cards = issue_cards|merge([{
    title:   item.entity.field_card_title.value,
    body:    item.entity.field_card_body.value,
    variant: item.entity.field_card_variant.value|default('default'),
  }]) %}
{% endfor %}

{% include "@components/issue-section/issue-section.twig" with {
  section_label:    paragraph.field_section_label.value,
  section_headline: paragraph.field_section_headline.value,
  lead_text:        paragraph.field_intro_text.value,
  body_text:        null,
  issue_cards:      issue_cards,
  attributes:       attributes,
} only %}
