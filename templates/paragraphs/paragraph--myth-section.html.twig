{#
/**
 * @file paragraph--myth-section.html.twig
 *
 * Paragraph bundle: MythSection
 * Component:        @components/myth-section/myth-section.twig
 *
 * MythItems reuse CardItem paragraph bundle with remapped semantics:
 *   field_card_title → myth text
 *   field_card_body  → fact text (filtered HTML, supports <strong>)
 *
 * Fields
 *   field_section_label    (string)       → section_label
 *   field_section_headline (string_long)  → section_headline (raw)
 *   field_intro_text       (text_long)    → intro text (optional)
 *   field_cards            (er_rev)       → myths[] from CardItem paragraphs
 */
#}
{% set myths = [] %}
{% for item in paragraph.field_cards %}
  {% set myths = myths|merge([{
    myth: item.entity.field_card_title.value,
    fact: item.entity.field_card_body.value,
  }]) %}
{% endfor %}

{% include "@components/myth-section/myth-section.twig" with {
  section_label:    paragraph.field_section_label.value,
  section_headline: paragraph.field_section_headline.value,
  myths:            myths,
  attributes:       attributes,
} only %}
