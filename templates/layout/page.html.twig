{#
/**
 * @file page.html.twig
 *
 * Regions:
 *   page.header      → Site header, main navigation
 *   page.highlighted → Drupal status messages
 *   page.content     → Main page content block
 *   page.footer      → Site footer
 *   page.disabled    → Parked blocks (never rendered)
 *
 * @see template_preprocess_page()
 * @see html.html.twig
 */
#}
{% extends '@layouts/site-container/site-container.twig' %}

  {% block header %}
    {{ page.header }}
  {% endblock %}

  {% block main %}
    {% if page.highlighted %}
      {{ page.highlighted }}
    {% endif %}
    {{ page.content }}
  {% endblock %}

  {% block footer %}
    {{ page.footer }}
  {% endblock %}
