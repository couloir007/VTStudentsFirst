{#
/**
 * @file region--header.html.twig
 *
 * Renders the Header region. This template owns the site-header wrapper
 * and passes the region's block content into the nav slot.
 *
 * Expected blocks in this region:
 *   - Main navigation menu block → rendered by block--system-menu-block--main.html.twig
 *     which outputs menu-main.twig
 *
 * The logo, <header> element, and nav wrapper live here.
 * The menu-main block renders inside the <nav>.
 *
 * @see site-header.twig
 * @see block--system-menu-block--main.html.twig
 * @see template_preprocess_region()
 */
#}
{% if content %}
  {{ attach_library('surface/site-header') }}
  <header id="header" class="site-header" data-drupal-selector="site-header" role="banner" data-once="navigation">
    <div class="site-header__container">
      <a href="{{ path('<front>') }}" class="site-header__logo" rel="home" aria-label="Our Kids Our Schools VT — Home">
        Our<span>Kids</span>Our<span>Schools</span>VT
      </a>
      <nav class="site-navigation" role="navigation" aria-label="Main navigation">
        {{ content }}
      </nav>
    </div>
  </header>
{% endif %}
